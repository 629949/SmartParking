# SmartPark Configuration Example
# Copy to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (optional - leave empty for SQLite)
DATABASE_URL=

# IoT - MQTT Broker Configuration
IOT_BROKER_HOST=192.168.1.100
IOT_BROKER_PORT=1883
IOT_BROKER_USER=
IOT_BROKER_PASSWORD=

# ESP32-S3 Configuration
ESP32_DEVICE_ID=smartpark-esp32-01
ESP32_DEVICE_NAME=SmartPark ESP32-S3 Controller
ESP32_WIFI_SSID=YOUR_NETWORK_NAME
ESP32_WIFI_PASSWORD=YOUR_WIFI_PASSWORD

# Parking Settings
PARKING_RATE_UGX=2000

# Payment Gateway (optional)
PAYMENT_GATEWAY=mock
PAYMENT_API_KEY=
PAYMENT_API_SECRET=

# Email Configuration (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Timezone
TIME_ZONE=Africa/Kampala
